APP_NAME="Bambi Knowledge Agent"
APP_ENV=development
HOST=0.0.0.0
PORT=8000
ADMIN_API_TOKEN=change-me

DATA_DIR=./data
SQLITE_PATH=./data/bambi.db
SESSION_DB_PATH=./data/agent_sessions.db

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=low
OPENAI_TEXT_VERBOSITY=low
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

MYBUSINESS_BASE_URL=https://api.mbapps.co.il/parse
MYBUSINESS_APP_ID=
MYBUSINESS_MASTER_KEY=
MYBUSINESS_TIMEOUT_SECONDS=20

INGEST_ON_STARTUP=false
